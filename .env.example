# Copy to .env and adjust. NEVER commit .env.

# Absolute path to the real data workspace (lives OUTSIDE this repo).
# Created by scripts/init_workspace.ts.
SECOND_BRAIN_WORKSPACE=/absolute/path/to/PersonalSecondBrainWorkspace

# Vault subdirectory inside the workspace.
SECOND_BRAIN_VAULT=${SECOND_BRAIN_WORKSPACE}/vault

# Event log directory (append-only JSONL; source of truth, not disposable).
SECOND_BRAIN_EVENTS=${SECOND_BRAIN_WORKSPACE}/events

# SQLite projection database (rebuildable from L0-L2 + events).
SECOND_BRAIN_DB=${SECOND_BRAIN_WORKSPACE}/db/memory.sqlite

# Retrieval indexes (disposable / rebuildable).
SECOND_BRAIN_INDEXES=${SECOND_BRAIN_WORKSPACE}/indexes

# --- Sidecars (NOT used in Phase 0/1; documented for later) ---
# TS<->Python contract mechanism for Phase 0/1 is stdio JSON/JSONL (no network).
# SIDECAR_RETRIEVAL_CMD=python sidecars/retrieval/main.py
# SIDECAR_AI_CMD=python sidecars/ai/main.py

# --- AI provider keys (NOT used in Phase 0/1) ---
# ANTHROPIC_API_KEY=
