{
  "name": "personal-second-brain",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first, open-format, domain-independent personal second brain core",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "init:workspace": "tsx scripts/init_workspace.ts",
    "verify:workspace": "tsx scripts/init_workspace.ts --verify",
    "validate:notes": "tsx scripts/validate_notes.ts",
    "index:vault": "tsx scripts/index_vault.ts",
    "query:memory": "tsx scripts/query_memory.ts",
    "test": "pnpm -r run test && pnpm run test:scripts",
    "test:scripts": "node --import tsx --test scripts/validate_notes.test.ts",
    "typecheck:scripts": "tsc -p scripts/tsconfig.json"
  },
  "devDependencies": {
    "@sb/note-vault": "workspace:*",
    "@types/node": "^25.9.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "yaml": "^2.5.0"
  },
  "comment": "Phase 0 scaffold. Script targets are stubs; no application logic yet."
}
