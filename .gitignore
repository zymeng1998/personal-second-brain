# ---------------------------------------------------------------------------
# PRIVACY-CRITICAL: never commit real personal or client data.
# The real data workspace lives OUTSIDE this repo (see .env / SECOND_BRAIN_WORKSPACE).
# These patterns are defense-in-depth in case a workspace is ever nested here.
# ---------------------------------------------------------------------------

# Real data workspace (any nesting)
PersonalSecondBrainWorkspace/
**/PersonalSecondBrainWorkspace/
workspace/
**/vault/
**/events/
**/indexes/
**/attachments/
**/secure_refs/
**/db/
*.sqlite
*.duckdb
*.jsonl
# Exception: synthetic, non-sensitive schema fixtures under examples/ (never real data).
!examples/**/*.jsonl

# Secrets / environment
.env
.env.*
!.env.example
secure_refs/
*.pem
*.key

# Sensitive document types (defense-in-depth)
*.pdf
*.passport
*_id.*
*_visa.*
*_bank*.*
*_paystub*.*
*_tax*.*

# Node / pnpm
node_modules/
dist/
build/
.turbo/
*.tsbuildinfo
.pnpm-store/

# Python sidecars (when implemented later)
__pycache__/
*.py[cod]
.venv/
venv/
.uv/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# Logs (technical/debug only; event logs live in the workspace, never here)
logs/
*.log
