{
  "name": "@sb/retrieval",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript facade over the Python retrieval sidecar (stdio JSONL transport). Indexes are L4 — disposable/rebuildable.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "test": "node --import tsx --test test/sidecar-client.test.ts test/query-memory.test.ts",
    "test:sidecar": "node --import tsx --test test/sidecar-integration.test.ts"
  },
  "dependencies": {
    "@sb/interfaces": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
